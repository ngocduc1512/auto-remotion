# Bắt buộc
ELEVENLABS_API_KEY=sk_xxx

# Voice ElevenLabs — eleven_v3 hỗ trợ tiếng Việt native
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL=eleven_v3

# Voice settings (Enhance = use_speaker_boost)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=true
ELEVENLABS_SPEED=1.0
ELEVENLABS_LANGUAGE_CODE=vi
# Auto-pick an EL v3 emotion tag ([excited]/[whispers]/etc) per chunk via LLM.
AUTO_EMOTION=true
# All-lowercase karaoke captions (visually consistent across sentence starts).
CAPTION_LOWERCASE=true

# Image gen: dùng Pollinations.ai (FREE, no key) — không cần config gì thêm

# Output
OUTPUT_DIR=./output
ASSETS_DIR=./assets
# Optional: auto-copy final.mp4 to this folder with a "YYYY-MM-DD HHMMSS - <topic>.mp4" name.
# Leave blank to skip.
EXPORT_DIR=/Volumes/KINGSTON/Auto-remotion

# Cover (thumbnail spliced as first frame so TikTok/Reels picks it as feed preview).
# Set to 0 to disable.
COVER_HOLD_SEC=0.1

# OPTIONAL: AI motion. 0 = disabled (vivify only). 999 = all frames.
ANIMATE_PUNCH_COUNT=0
# Backend A (free, Apple Silicon only): LTX Video on-device via MPS.
LOCAL_I2V=false
# Backend B (cloud, ~$0.035/clip): Replicate Wan 2.2. Used when LOCAL_I2V=false.
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_MODEL=wan-video/wan-2.2-i2v-fast
