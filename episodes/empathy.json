  "captions": [
    { "from": 0.20,  "to": 2.64,  "text": "Bạn có thể thắng trong mọi cuộc tranh cãi...", "emphasis": "thắng",       "size": "heading", "align": "top" },
    { "from": 2.78,  "to": 3.92,  "text": "mà vẫn cô đơn...",                              "emphasis": "cô đơn",      "size": "title",   "align": "center" },
    { "from": 3.95,  "to": 5.04,  "text": "trong chính ngôi nhà mình.",                    "emphasis": "nhà mình",    "size": "title",   "align": "center" },
    { "from": 5.47,  "to": 7.23,  "text": "Nghe đau, nhưng là thật.",                      "emphasis": "đau",         "size": "title",   "align": "center" },

    { "from": 7.56,  "to": 9.52,  "text": "Tôi từng biết một người rất giỏi lý lẽ.",       "emphasis": "giỏi lý lẽ",  "size": "heading", "align": "top" },
    { "from": 9.73,  "to": 12.40, "text": "Nói chuyện với ai, anh cũng phải là người đúng.", "emphasis": "phải đúng", "size": "subtitle", "align": "bottom" },

    { "from": 12.80, "to": 18.48, "text": "Vợ buồn kể một chuyện, anh lập tức phân tích: \"em sai chỗ này, đáng lẽ phải làm thế kia\".", "emphasis": "phân tích", "size": "subtitle", "align": "top" },
    { "from": 18.66, "to": 19.52, "text": "Anh đúng.",                                     "emphasis": "đúng",        "size": "title",   "align": "center" },
    { "from": 19.76, "to": 20.80, "text": "Lúc nào cũng đúng.",                            "emphasis": "cũng đúng",   "size": "title",   "align": "center" },

    { "from": 21.54, "to": 23.36, "text": "Nhưng dần dần, vợ anh thôi kể.",                "emphasis": "thôi kể",     "size": "heading", "align": "bottom" },
    { "from": 23.52, "to": 24.96, "text": "Con anh thôi tâm sự.",                          "emphasis": "thôi tâm sự", "size": "title",   "align": "center" },
    { "from": 25.12, "to": 26.96, "text": "Ngôi nhà vẫn đủ người...",                      "size": "heading", "align": "top" },
    { "from": 27.04, "to": 28.24, "text": "mà lạnh lẽo lạ thường.",                        "emphasis": "lạnh lẽo",    "size": "title",   "align": "center" },

    { "from": 29.15, "to": 32.25, "text": "Một ngày anh hỏi tôi:",                          "size": "subtitle", "align": "bottom" },
    { "from": 32.31, "to": 36.97, "text": "\"Anh có làm gì sai đâu... sao ai cũng xa anh?\"", "emphasis": "xa anh", "size": "heading", "align": "center" },

    { "from": 37.42, "to": 41.00, "text": "Bạn có thấy mình, dù chỉ một chút, trong đó không?", "emphasis": "một chút", "size": "subtitle", "align": "center" },

    { "from": 41.00, "to": 44.97, "text": "Trí Tuệ Cảm Xúc nói: khi một người chia sẻ cảm xúc...", "emphasis": "chia sẻ",  "size": "subtitle", "align": "bottom" },
    { "from": 45.18, "to": 46.89, "text": "họ không tìm một quan toà phân xử đúng sai.",   "emphasis": "quan toà",   "size": "heading", "align": "top" },
    { "from": 46.94, "to": 47.61, "text": "Họ chỉ tìm một người... chịu HIỂU.",           "emphasis": "HIỂU",       "size": "heading", "align": "bottom" },

    { "from": 48.09, "to": 49.77, "text": "Đồng cảm không phải là đồng ý.",                "emphasis": "không phải đồng ý", "size": "heading", "align": "top" },
    { "from": 49.98, "to": 55.00, "text": "Nó chỉ là bước sang phía bên kia, và nói:",     "emphasis": "phía bên kia", "size": "subtitle", "align": "bottom" },
    { "from": 55.00, "to": 57.50, "text": "\"Anh hiểu vì sao em thấy như vậy.\"",          "emphasis": "hiểu",        "size": "heading", "align": "center" },

    { "from": 57.60, "to": 58.41, "text": "Nên lần tới, khi ai đó buồn kể với bạn...",     "size": "subtitle", "align": "top" },
    { "from": 58.45, "to": 59.37, "text": "đừng vội sửa.",                                  "emphasis": "sửa",         "size": "title",   "align": "center" },
    { "from": 59.53, "to": 60.33, "text": "Đừng vội khuyên.",                               "emphasis": "khuyên",      "size": "title",   "align": "center" },
    { "from": 60.61, "to": 62.17, "text": "Đừng vội chứng minh họ sai.",                    "emphasis": "chứng minh",  "size": "heading", "align": "top" },

    { "from": 62.43, "to": 63.77, "text": "Hãy chỉ lắng nghe.",                             "emphasis": "lắng nghe",   "size": "title",   "align": "center" },
    { "from": 63.96, "to": 66.21, "text": "Và cho họ thấy... họ không một mình.",           "emphasis": "không một mình", "size": "heading", "align": "bottom" },

    { "from": 66.94, "to": 70.65, "text": "Điều người ta cần... không phải một câu trả lời đúng.", "emphasis": "trả lời đúng", "size": "subtitle", "align": "top" },
    { "from": 71.12, "to": 73.37, "text": "Mà chỉ là một người... thật sự hiểu.",           "emphasis": "thật sự hiểu", "size": "heading", "align": "bottom" }
  ],

