  "captions": [
    { "from": 0.14,  "to": 2.24,  "text": "Bạn không kiểm soát được cảm xúc của mình...", "emphasis": "kiểm soát", "size": "heading", "align": "top" },
    { "from": 2.28,  "to": 4.72,  "text": "đơn giản vì bạn còn chưa gọi đúng tên nó.",     "emphasis": "gọi đúng tên",  "size": "subtitle", "align": "bottom" },
    { "from": 5.25,  "to": 6.16,  "text": "Nghe lạ không?",                                  "size": "title",  "align": "center" },
    { "from": 6.28,  "to": 7.56,  "text": "Nhưng ngẫm mà xem.",                              "size": "title",  "align": "center" },

    { "from": 8.44,  "to": 12.64, "text": "Tôi từng có một giai đoạn lúc nào cũng thấy khó chịu, bồn chồn, dễ cáu.", "emphasis": "khó chịu, bồn chồn, dễ cáu", "size": "subtitle", "align": "top" },
    { "from": 12.84, "to": 14.72, "text": "Tôi cứ nghĩ mình đang tức giận.",                 "emphasis": "tức giận", "size": "heading", "align": "bottom" },

    { "from": 15.17, "to": 19.76, "text": "Cho đến một ngày, có người hỏi tôi một câu đơn giản:", "size": "subtitle", "align": "top" },
    { "from": 19.82, "to": 23.13, "text": "\"Cậu đang giận... hay thật ra cậu đang SỢ?\"",  "emphasis": "SỢ", "size": "heading", "align": "center" },
    { "from": 23.45, "to": 25.93, "text": "Hoá ra suốt thời gian đó, tôi không hề giận.",   "emphasis": "không hề giận", "size": "subtitle", "align": "top" },
    { "from": 26.11, "to": 27.21, "text": "Tôi đang sợ.",                                    "emphasis": "sợ", "size": "title", "align": "center" },
    { "from": 27.53, "to": 30.09, "text": "Sợ mình thất bại, sợ không đủ giỏi.",             "emphasis": "thất bại", "size": "heading", "align": "top" },

    { "from": 30.95, "to": 32.65, "text": "Chỉ cần gọi đúng tên nó thôi...",                 "emphasis": "gọi đúng tên", "size": "heading", "align": "bottom" },
    { "from": 32.69, "to": 34.41, "text": "cơn bão trong lòng tôi dịu hẳn đi.",              "emphasis": "dịu hẳn đi", "size": "heading", "align": "top" },

    { "from": 35.47, "to": 36.73, "text": "Bạn có thấy mình trong đó không?",                "size": "heading", "align": "center" },
    { "from": 36.85, "to": 40.85, "text": "Những lúc lòng rối bời mà chẳng biết chính xác mình đang cảm thấy gì.", "emphasis": "rối bời", "size": "subtitle", "align": "top" },

    { "from": 41.11, "to": 46.09, "text": "Trí Tuệ Cảm Xúc dạy: một cảm xúc không được gọi tên...", "emphasis": "không được gọi tên", "size": "subtitle", "align": "bottom" },
    { "from": 46.14, "to": 48.21, "text": "sẽ điều khiển bạn từ trong bóng tối.",            "emphasis": "bóng tối", "size": "heading", "align": "top" },
    { "from": 48.39, "to": 51.77, "text": "Còn khi bạn gọi được tên nó, bạn kéo nó ra ánh sáng.", "emphasis": "ánh sáng", "size": "subtitle", "align": "bottom" },
    { "from": 52.04, "to": 55.13, "text": "Và thứ gì bị nhìn thẳng... đều bớt đáng sợ đi.",  "emphasis": "bớt đáng sợ", "size": "heading", "align": "center" },

    { "from": 55.92, "to": 58.81, "text": "Lần tới, khi trong lòng cồn cào khó chịu...",     "size": "subtitle", "align": "top" },
    { "from": 58.89, "to": 59.77, "text": "đừng vội đè nén.",                                 "emphasis": "đè nén", "size": "title", "align": "center" },
    { "from": 59.97, "to": 61.29, "text": "Cũng đừng vội bùng nổ.",                           "emphasis": "bùng nổ", "size": "title", "align": "center" },

    { "from": 61.74, "to": 65.53, "text": "Hãy dừng lại và tự hỏi:",                          "size": "subtitle", "align": "center" },
    { "from": 65.74, "to": 69.45, "text": "\"Mình đang thật sự cảm thấy gì? Và vì sao?\"",    "emphasis": "cảm thấy gì", "size": "heading", "align": "center" },

    { "from": 69.49, "to": 71.53, "text": "Bạn đã đi từ nạn nhân của cảm xúc...",             "emphasis": "nạn nhân", "size": "heading", "align": "bottom" },
    { "from": 71.56, "to": 72.73, "text": "thành người quan sát nó.",                          "emphasis": "người quan sát", "size": "title", "align": "top" },

    { "from": 73.73, "to": 75.45, "text": "Bạn không cần dập tắt cảm xúc của mình.",          "emphasis": "không cần dập tắt", "size": "heading", "align": "top" },
    { "from": 75.60, "to": 78.89, "text": "Bạn chỉ cần... hiểu nó đang cố nói với bạn điều gì.", "emphasis": "hiểu nó", "size": "heading", "align": "bottom" }
  ],

