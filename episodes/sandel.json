      "text": "anh trai ruột của mình.",
      "emphasis": "anh trai ruột",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 21.46,
      "to": 22.5,
      "text": "Báo cảnh sát?",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 22.68,
      "to": 24.28,
      "text": "Anh trai có thể lãnh án tử.",
      "emphasis": "án tử",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 24.53,
      "to": 25.2,
      "text": "Im lặng?",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 25.52,
      "to": 26.95,
      "text": "Sẽ có thêm người chết.",
      "emphasis": "người chết",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 27.18,
      "to": 28.9,
      "text": "Câu chuyện đó nằm trong cuốn sách này.",
      "align": "bottom",
      "size": "subtitle"
    },
    {
      "from": 29.12,
      "to": 35.7,
      "text": "Phải Trái Đúng Sai — Michael Sandel, giáo sư Harvard.",
      "emphasis": "Michael Sandel",
      "align": "bottom",
      "size": "subtitle"
    },
    {
      "from": 35.97,
      "to": 37.9,
      "text": "Cuốn sách không dạy bạn đáp án.",
      "emphasis": "đáp án",
      "align": "bottom",
      "size": "heading"
    },
    {
      "from": 38.05,
      "to": 39.7,
      "text": "Nó làm điều khó chịu hơn nhiều...",
      "align": "bottom",
      "size": "heading"
    },
    {
      "from": 39.86,
      "to": 42.1,
      "text": "bắt bạn thấy mình mâu thuẫn với chính mình.",
      "emphasis": "mâu thuẫn",
      "align": "bottom",
      "size": "heading"
    },
    {
      "from": 42.32,
      "to": 45.55,
      "text": "Sandel chỉ ra 3 cách con người phán xử.",
      "emphasis": "3 cách",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 45.8,
      "to": 47.4,
      "text": "Một, lợi ích chung...",
      "emphasis": "lợi ích chung",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 47.56,
      "to": 48.98,
      "text": "cứu nhiều người là đúng.",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 49.24,
      "to": 50.6,
      "text": "Hai, nguyên tắc...",
      "emphasis": "nguyên tắc",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 50.75,
      "to": 52.5,
      "text": "luật là luật, không ngoại lệ.",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 52.85,
      "to": 54.55,
      "text": "Ba, lòng trung thành...",
      "emphasis": "trung thành",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 54.64,
      "to": 57.15,
      "text": "ta nợ gia đình những gì không nợ người lạ.",
      "emphasis": "gia đình",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 57.41,
      "to": 59.05,
      "text": "Nghe cách nào cũng có lý.",
      "align": "bottom",
      "size": "heading"
    },
    {
      "from": 59.2,
      "to": 61.25,
      "text": "Nhưng đặt vào chuyện của David...",
      "align": "bottom",
      "size": "heading"
    },
    {
      "from": 61.33,
      "to": 63.05,
      "text": "ba cái lý cắn nhau chí tử.",
      "emphasis": "cắn nhau",
      "align": "bottom",
      "size": "heading"
    },
    {
      "from": 63.32,
      "to": 66.5,
      "text": "2000 năm trước, Khổng Tử cũng bị hỏi câu này.",
      "emphasis": "Khổng Tử",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 69.5,
      "to": 71.45,
      "text": "Loài người hỏi mãi một câu hỏi...",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 71.65,
      "to": 73.0,
      "text": "vì chưa ai trả lời xong.",
      "emphasis": "chưa ai trả lời",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 73.23,
      "to": 74.85,
      "text": "David, cuối cùng...",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 74.99,
      "to": 76.35,
      "text": "đã báo cho FBI.",
      "emphasis": "báo cho FBI",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 76.54,
      "to": 77.95,
      "text": "Với một điều kiện duy nhất.",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 79.78,
      "to": 81.05,
      "text": "Ông chọn cả hai...",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 81.25,
      "to": 83.0,
      "text": "và mất cả hai, một phần.",
      "emphasis": "mất cả hai",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 83.44,
      "to": 87.2,
      "text": "Đọc sách này, bạn không giỏi phán xét hơn.",
      "align": "top",
      "size": "subtitle"
    },
    {
      "from": 87.37,
      "to": 89.15,
      "text": "Nhưng bạn sẽ bớt chắc chắn...",
      "align": "top",
      "size": "heading"
    },
    {
      "from": 89.24,
      "to": 90.05,
      "text": "một cách nông cạn.",
